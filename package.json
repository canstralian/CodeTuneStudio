  "version": "0.2.0",
  "description": "Cloudflare Worker for CodeTuneStudio API",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
