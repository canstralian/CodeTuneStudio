    "tail:staging": "wrangler tail --env staging",
    "login": "wrangler login",
    "logout": "wrangler logout",
    "test": "echo 'No tests configured yet'",
    "build": "echo 'No build step required'"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "codetune",
    "api",
    "code-analysis"
  ],
